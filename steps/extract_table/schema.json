{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["table"],
  "properties": {
    "table": {
      "description": "Table with EQUITIES RETURN ESTIMATES, or null if no relevant table is present.",
      "anyOf": [
        {
          "type": "object",
          "required": ["headers", "rows"],
          "properties": {
            "title": { "type": ["string", "null"] },
            "headers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {}
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
